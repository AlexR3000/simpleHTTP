{
    "version": 3,
    "configurePresets": [
        {
            "name": "docker-linux",
            "displayName": "Docker Linux GCC",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
          "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "VCPKG_ROOT": "${sourceDir}/external/vcpkg",
            "VCPKG_FEATURE_FLAGS": "manifests",
            "CMAKE_C_COMPILER": "/usr/local/bin/gcc",
            "CMAKE_CXX_COMPILER": "/usr/local/bin/g++"
          },
            "toolchainFile": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake"
        }
    ]
}